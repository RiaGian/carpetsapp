{
  "expo": {
    "name": "carpets-app",
    "slug": "carpets-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "carpetsapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "platforms": ["ios", "android", "web"],

    "ios": {
      "bundleIdentifier": "com.carpetsapp.carpetsapp",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Χρησιμοποιούμε το Face ID για γρήγορη και ασφαλή σύνδεση."
      }
    },

    "android": {
      "package": "com.carpetsapp.carpetsapp",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": { "backgroundColor": "#000000" }
        }
      ]
    ],

    "assetBundlePatterns": ["**/*"],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
